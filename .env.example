# Hugging Face 模型缓存目录（transformers 和 hub 缓存会自动放在其子目录下）
HF_HOME=/path/to/your/cache

# Hugging Face 镜像站（解决网络连接问题）
HF_ENDPOINT=https://hf-mirror.com

# 如果需要代理，取消下面注释并配置
# HTTP_PROXY=http://your-proxy:port
# HTTPS_PROXY=http://your-proxy:port

# Wan2.1 checkpoint 目录（需含 models_t5_umt5-xxl-enc-bf16.pth 等文件，覆盖 --ckpt_dir）
# WAN2_CKPT_DIR=/path/to/your/models/Wan2.1-I2V-14B-480P
# Wan2.2 checkpoint 目录（需含 models_t5_umt5-xxl-enc-bf16.pth、low_noise_model/、high_noise_model/ 等，覆盖 --ckpt_dir）
WAN2_CKPT_DIR=/path/to/your/models/Wan2.2-I2V-A14B

# OpenAI API 配置(如果使用)
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# VLM 模型配置
# 如果需要使用本地 VLM,设置为 1
# IFEDIT_USE_LOCAL_VLM=1
# IFEDIT_QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
